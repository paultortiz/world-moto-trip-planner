generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?

  role           UserRole @default(USER)
  locale         String?  // User's preferred language (e.g., "en", "es")
  passportCountries Json?  // Array of ISO 3166-1 alpha-2 codes for visa/entry requirements

  // Rider preferences for AI personalization
  ridingStyle        RidingStyle?
  pacePreference     PacePreference?
  terrainPreference  TerrainPreference?
  experienceLevel    ExperienceLevel?
  dailyDistanceKm    Int?              // Preferred daily riding distance
  interests          Json?             // Array: ["scenicRoutes", "localCuisine", "historicSites", "photography", "camping", "twistyRoads"]
  avoidHighways      Boolean           @default(false)
  preferCamping      Boolean           @default(false)
  dietaryRestrictions String?          // For food recommendations

  accounts       Account[]
  sessions       Session[]
  trips          Trip[]
  motorcycles    Motorcycle[]
  activityLogs   ActivityLog[]

  lastActiveAt   DateTime?  // Last activity timestamp for retention tracking

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trip {
  id                   String         @id @default(cuid())
  userId               String
  user                 User           @relation(fields: [userId], references: [id])

  name                 String
  description          String?
  isPublic             Boolean        @default(false)
  shareToken           String?        @unique
  startDate            DateTime?
  endDate              DateTime?
  totalDistanceMeters  Int?
  totalDurationSeconds Int?

  // Optional fuel planning settings (range in kilometers)
  fuelRangeKm          Int?
  fuelReserveKm        Int?
  fuelAutoFromMotorcycle Boolean? @default(true)

  // Optional elevation summary (meters)
  totalAscentMeters    Int?
  totalDescentMeters   Int?
  maxElevationMeters   Int?

  // Optional schedule realism settings
  plannedDailyRideHours Int?
  earliestDepartureHour Int?
  latestArrivalHour     Int?

  // Optional per-segment risk/notes metadata, indexed by segment order
  // (0 = segment from waypoint[0] → waypoint[1], etc.)
  segmentNotes          Json?

  // AI-generated daily plan (markdown text and structured JSON)
  aiDailyPlan           String?   @db.Text
  aiDailyPlanStructured Json?
  aiDailyPlanGeneratedAt DateTime?

  // Route preference flags
  routeAvoidHighways   Boolean  @default(false)
  routeAvoidTolls      Boolean  @default(false)
  routeAvoidFerries    Boolean  @default(false)

  // AI-classified terrain segments along the route
  terrainClassification Json?

  // Optional associated motorcycle for this trip
  motorcycleId          String?
  motorcycle            Motorcycle?    @relation(fields: [motorcycleId], references: [id])

  waypoints            Waypoint[]
  routeSegments        RouteSegment[]
  checklistItems       TripChecklistItem[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Waypoint {
  id            String          @id @default(cuid())
  tripId        String
  trip          Trip            @relation(fields: [tripId], references: [id])

  orderIndex    Int
  lat           Float
  lng           Float
  name          String?
  type          WaypointType    @default(CHECKPOINT)
  notes         String?

  // Optional Google Places metadata for this waypoint (when created from a place search)
  googlePlaceId String?

  // Optional day index for multi-day planning (1-based)
  dayIndex      Int?

  // Whether this waypoint marks an overnight stop (day boundary)
  isOvernightStop Boolean @default(false)

  startSegments RouteSegment[]  @relation("RouteSegmentStart")
  endSegments   RouteSegment[]  @relation("RouteSegmentEnd")

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model RouteSegment {
  id                 String    @id @default(cuid())
  tripId             String
  trip               Trip      @relation(fields: [tripId], references: [id])

  startWaypointId    String?
  startWaypoint      Waypoint? @relation("RouteSegmentStart", fields: [startWaypointId], references: [id])

  endWaypointId      String?
  endWaypoint        Waypoint? @relation("RouteSegmentEnd", fields: [endWaypointId], references: [id])

  distanceMeters     Int?
  durationSeconds    Int?
  polyline           String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TripChecklistItem {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  orderIndex  Int
  label       String
  isDone      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Motorcycle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year        Int?
  make        String?
  model       String?
  displayName String?

  engineDisplacementCc Int?
  wetWeightKg          Int?
  fuelCapacityLiters   Float?
  estimatedRangeKm     Int?
  seatHeightMm         Int?
  offroadBias          Float?
  highwayComfort       Float?

  preferredRangeKm     Int?
  preferredReserveKm   Int?

  isDefaultForNewTrips Boolean  @default(false)

  specs               Json?
  maintenanceSchedule Json?

  trips       Trip[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, year, make, model])
}

enum WaypointType {
  FUEL
  LODGING
  CAMPGROUND
  DINING
  POI
  CHARGING
  BORDER
  CHECKPOINT
  VIA
  OTHER
}

enum UserRole {
  USER
  ADMIN
  SPONSOR
}

enum RidingStyle {
  TOURING
  ADVENTURE
  OFFROAD
  SPORT_TOURING
}

enum PacePreference {
  RELAXED
  MODERATE
  AGGRESSIVE
}

enum TerrainPreference {
  PAVEMENT_ONLY
  MIXED
  OFFROAD_FOCUSED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "trip.created", "ai_plan.generated"
  metadata  Json?    // Additional context (tripId, etc.)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// Cache for AI-generated motorcycle model lists by make
// Shared across all users to minimize OpenAI API calls
model MotorcycleModelCache {
  id        String   @id @default(cuid())
  make      String   @unique  // Normalized make name (e.g., "Yamaha")
  models    Json     // Array of model names sorted alphabetically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([make])
}

// Cache for AI-generated border crossing requirements by country pair
// Shared across all users since requirements don't change per-user
model BorderRequirementsCache {
  id              String   @id @default(cuid())
  originCountry   String   // ISO 3166-1 alpha-2 (e.g., "US")
  destCountry     String   // ISO 3166-1 alpha-2 (e.g., "MX")
  requirements    Json     // Array of BorderRequirement objects
  warnings        Json?    // Optional array of warning strings
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([originCountry, destCountry])
  @@index([originCountry, destCountry])
}

// Curated vehicle entry requirements by destination country
// Contains structured TIP and Carnet de Passages information
model VehicleEntryRequirement {
  id                  String    @id @default(cuid())
  destCountry         String    @unique // ISO 3166-1 alpha-2
  countryName         String    // Human-readable name

  // Temporary Import Permit (TIP) fields
  tipRequired         Boolean   @default(true)
  tipCostUsd          Float?    // Approximate cost in USD
  tipValidityDays     Int?      // How long TIP is valid
  tipObtainAt         String?   // "border", "online", "consulate", "advance"
  tipAgency           String?   // e.g., "Banjercito", "Aduana Nacional"
  tipUrl              String?   // Official application URL
  tipDocuments        Json?     // Array of required document strings
  tipNotes            String?   @db.Text // Free-form notes/tips
  tipProcessingDays   Int?      // Typical processing time if applying in advance

  // Carnet de Passages fields
  carnetRequired      Boolean   @default(false)
  carnetAccepted      Boolean   @default(true) // Some countries accept but don't require
  carnetIssuers       Json?     // Array of {country, org, url}
  carnetNotes         String?   @db.Text
  carnetProcessingWeeks Int?    // Typical processing time

  // Deposit requirements
  depositRequired     Boolean   @default(false)
  depositAmountUsd    Float?    // Approximate deposit amount
  depositRefundable   Boolean   @default(true)
  depositNotes        String?   // How/when to get deposit back

  // Insurance requirements
  insuranceRequired   Boolean   @default(true)
  insuranceNotes      String?   // Where to buy, typical costs

  // Metadata
  sourceUrl           String?   // Primary source for this info
  lastVerified        DateTime? // When this info was last verified
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([destCountry])
}

// Border crossing cache - populated from Google Places API
// Contains location data from Google + AI-enhanced motorcycle tips
model BorderCrossing {
  id                  String    @id @default(cuid())
  googlePlaceId       String    @unique // Google Places unique identifier
  
  // Location data from Google Places
  name                String    // Place name from Google
  lat                 Float
  lng                 Float
  address             String?   // Formatted address
  rating              Float?    // Google rating (1-5)
  userRatingsTotal    Int?      // Number of ratings
  openingHours        Json?     // Opening hours from Google
  phoneNumber         String?   // Phone number if available
  websiteUrl          String?   // Official website if available
  photoReferences     Json?     // Array of Google photo references
  placeTypes          Json?     // Array of place types from Google
  
  // Derived location context
  fromCountry         String?   // ISO 3166-1 alpha-2, derived from reverse geocoding
  toCountry           String?   // ISO 3166-1 alpha-2, derived from reverse geocoding
  
  // AI-enhanced motorcycle-specific info (populated on-demand)
  motorcycleTips      String?   @db.Text // AI-generated tips for motorcyclists
  warnings            String?   @db.Text // AI-generated warnings/cautions
  bestTimeToGo        String?   // AI-suggested best times to cross
  tipProcessInfo      String?   @db.Text // AI info about TIP/permit process at this crossing
  lastAiEnhanced      DateTime? // When AI enhancement was last run

  // Cache metadata
  lastFetched         DateTime  @default(now()) // When data was fetched from Google
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([lat, lng])
  @@index([fromCountry, toCountry])
}
